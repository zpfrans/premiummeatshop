{
  "name": "backend",
  "version": "1.0.0",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate:up": "node-pg-migrate up -m migrations",
    "migrate:down": "node-pg-migrate down -m migrations",
    "seed": "node scripts/seed.js",
    "backup:db": "sh ./scripts/backup-postgres.sh",
    "restore:db": "sh ./scripts/restore-postgres.sh",
    "backup:db:win": "powershell -ExecutionPolicy Bypass -File ./scripts/backup-postgres.ps1",
    "restore:db:win": "powershell -ExecutionPolicy Bypass -File ./scripts/restore-postgres.ps1",
    "lint": "eslint ."
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "Production backend for Farmer's Premium Meatshop",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-rate-limit": "^8.1.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "pg": "^8.16.3",
    "pino": "^10.0.0",
    "pino-http": "^11.0.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "eslint": "^10.2.1",
    "node-pg-migrate": "^8.0.4",
    "nodemon": "^3.1.14",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2",
    "vitest": "^4.1.5"
  }
}
